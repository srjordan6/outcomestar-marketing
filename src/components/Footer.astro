---
const year = new Date().getFullYear();
---
<footer class="border-t border-slate-800/50 mt-24">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-sm">
      <div class="flex items-center gap-2">
        <span class="text-flame text-lg">&#10022;</span>
        <span class="text-white font-medium">OutcomeStar</span>
      </div>
      <p class="text-slate-500">
        Questions: <a href="mailto:support@outcomestar.app" class="text-slate-300 hover:text-flame transition-colors">support@outcomestar.app</a>
      </p>
    </div>
    <p class="text-xs text-slate-600 mt-6">&copy; {year} OutcomeStar.</p>
  </div>
</footer>