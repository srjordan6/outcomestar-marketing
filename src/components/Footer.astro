---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800/50 mt-32">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 text-sm">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-flame text-lg">&#10022;</span>
          <span class="text-white font-medium">Outcomestar</span>
        </div>
        <p class="text-slate-500 max-w-md text-sm leading-relaxed">
          The family operating system for college admissions. Track every
          activity, every achievement, every step from middle school to your
          North Star.
        </p>
      </div>
      <div>
        <h3 class="text-white text-xs uppercase tracking-wider mb-4">Product</h3>
        <ul class="space-y-2 text-slate-400">
          <li><a href="/pricing" class="hover:text-white transition">Pricing</a></li>
          <li><a href="/signup" class="hover:text-white transition">Get started</a></li>
          <li><a href="/login" class="hover:text-white transition">Sign in</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white text-xs uppercase tracking-wider mb-4">Company</h3>
        <ul class="space-y-2 text-slate-400">
          <li><a href="/about" class="hover:text-white transition">About</a></li>
          <li><a href="/privacy" class="hover:text-white transition">Privacy</a></li>
          <li><a href="/terms" class="hover:text-white transition">Terms</a></li>
          <li>
            <a href="mailto:support@outcomestar.app" class="hover:text-white transition">
              support@outcomestar.app
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-6 border-t border-slate-800/50 text-xs text-slate-600 flex flex-col md:flex-row justify-between gap-3">
      <p>© {year} Outcomestar. Built for families who aim higher.</p>
      <p>Account changes &amp; support: <a href="mailto:support@outcomestar.app" class="hover:text-slate-400">support@outcomestar.app</a></p>
    </div>
  </div>
</footer>