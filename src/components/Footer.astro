  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <a href="/" class="flex items-baseline gap-2"><span class="text-srj-orange text-lg leading-none">&#10022;</span><span class="text-srj-navy font-headline font-semibold tracking-tight">OutcomeStar</span></a>
      <p class="font-body text-sm text-srj-gray">Questions: <a href="mailto:support@outcomestar.app" class="text-srj-navy hover:text-srj-orange transition-colors font-medium">support@outcomestar.app</a></p>
    </div>
    <p class="font-body text-xs text-srj-gray mt-6">&copy; {year} OutcomeStar &middot; an SRJ Consulting &amp; Services platform.</p>
  </div>
</footer>