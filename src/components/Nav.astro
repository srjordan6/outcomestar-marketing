---
const navLinks = [
  { href: "/pricing", label: "Pricing" },
  { href: "/about", label: "About" },
];
---

<nav class="border-b border-slate-800/50 backdrop-blur-sm bg-navy-950/80 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group"><span class="text-flame text-xl">&#10022;</span><span class="text-white font-medium tracking-tight">OutcomeStar</span></a>
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (<a href={link.href} class="text-slate-400 hover:text-white text-sm transition-colors">{link.label}</a>))}
      <a href="/login" class="text-slate-400 hover:text-white text-sm transition-colors">Sign in</a>
      <a href="/signup" class="bg-flame hover:bg-flame/90 text-white text-sm font-medium px-4 py-2 rounded transition-colors">Get started</a>
    </div>
    <a href="/signup" class="md:hidden bg-flame text-white text-sm font-medium px-3 py-1.5 rounded">Start</a>
  </div>
</nav>