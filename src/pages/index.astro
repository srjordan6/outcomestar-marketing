.who-band{max-width:760px;margin:0 auto 20px;background:#ECEAF6;border:1px solid #DDD9EE;border-radius:12px;padding:16px 22px;font-size:15px;color:#4A5563;text-align:left}
.who-band b{color:var(--navy)}
.trust{max-width:640px;margin:0 auto 26px;font-size:14px;color:var(--gray);font-style:italic}
.rule{width:110px;border-bottom:3px solid var(--orange);margin:22px auto}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:22px;padding:32px 0 20px}
.card{background:#fff;border:1px solid #E3E7ED;border-radius:14px;padding:26px}
.card h3{font-size:19px;margin-bottom:8px}
.card p{margin:0;color:#4A5563;font-size:14.5px}
.card.pain{border-top:4px solid var(--orange)}
.sect-head{text-align:center;padding-top:44px}
.sect-head h2{font-size:clamp(24px,3.4vw,32px)}
.cta-row{text-align:center;padding:8px 0 44px}
.feature{padding:64px 0;text-align:center;border-bottom:1px solid #E9E6DD}
.feature.alt{background:#fff}
.feature h2{font-size:clamp(26px,3.8vw,36px)}
.feature p.lead{max-width:640px;margin:16px auto 12px;font-size:17px;color:#4A5563}
.feature p.more{max-width:640px;margin:0 auto 26px;font-size:14.5px;color:var(--gray)}
.timeline{background:#fff;border:1px solid #E3E7ED;border-radius:14px;padding:24px 26px;margin:28px 0 8px}
.tl-row{display:grid;grid-template-columns:150px 1fr;gap:14px;padding:12px 0;border-bottom:1px solid #EFEDE6;font-size:14.5px}
.tl-row:last-child{border-bottom:0}
.tl-when{font-weight:600;color:var(--navy)}
.tl-what{color:#4A5563}
.band{background:var(--navy);color:#fff;text-align:center;padding:56px 24px;margin-top:0}
.band h2{color:#fff;font-size:30px}
.band p{color:#C9C6E4;max-width:620px;margin:14px auto 26px}
@media(max-width:760px){.tl-row{grid-template-columns:1fr}}
footer{border-top:1px solid #E5E2D9;margin-top:0;padding:26px 20px;text-align:center;font-size:13px;color:var(--gray);background:var(--paper)}
footer a{color:var(--navy);text-decoration:none}
