<style is:global>
:root{--navy:#201868;--orange:#F07800;--paper:#FAFAF7;--gray:#7A8A9E;--ink:#1a1a2e}
*{box-sizing:border-box}body{margin:0;font-family:Poppins,sans-serif;background:var(--paper);color:var(--ink);line-height:1.6}
h1,h2,h3{font-family:Lora,Georgia,serif;color:var(--navy);margin:0}
.wrap{max-width:1020px;margin:0 auto;padding:0 24px}
.narrow{max-width:720px;margin:0 auto;padding:0 24px}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:8px 18px;border-bottom:1px solid #E5E2D9;background:#fff}
.topbar nav{display:flex;gap:18px;font-size:14px;align-items:center;flex-wrap:wrap}
.topbar nav a{color:var(--navy);text-decoration:none}
.topbar nav a.cta-in{color:#fff;background:var(--navy);padding:6px 14px;border-radius:8px;font-weight:600}
.topbar nav a.cta-up{color:#fff;background:var(--orange);padding:6px 14px;border-radius:8px;font-weight:600}
.btn{display:inline-block;background:var(--orange);color:#fff;font-weight:600;padding:12px 28px;border-radius:10px;text-decoration:none;border:0;font-size:16px;cursor:pointer}
.btn:hover{background:#C46300}
.sub{display:block;margin-top:8px;font-size:13px;color:var(--gray)}
.kicker{display:inline-block;font-size:12px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--orange);margin-bottom:10px}
.hero{padding:56px 0 48px;text-align:center}
.hero h1{font-size:clamp(32px,5.5vw,54px);line-height:1.15;letter-spacing:-.01em}
.hero h1 span{color:var(--orange)}
.hero p{max-width:660px;margin:18px auto 30px;font-size:18px;color:#4A5563}
