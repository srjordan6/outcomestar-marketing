---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Get started â€” Outcomestar">
  <section class="py-16 md:py-24">
    <div class="max-w-md mx-auto px-6">
      <p class="text-xs uppercase tracking-wider text-flame mb-3">Get started</p>
      <h1 class="text-3xl md:text-4xl text-white font-light mb-3">Welcome to Outcomestar.</h1>
      <p class="text-slate-400 mb-10 leading-relaxed">Enter your pairing code below to access your family workspace.</p>
      <form id="signup-form" class="space-y-4">
        <div>
          <label for="code" class="block text-xs uppercase tracking-wider text-slate-500 mb-2">Pairing code</label>
          <input type="text" id="code" name="code" required autocomplete="off" placeholder="XXXXXX"
            class="w-full bg-navy-900 border border-slate-700 text-white px-4 py-3 rounded font-mono tracking-widest text-lg focus:outline-none focus:border-flame transition-colors" />
        </div>
        <button type="submit" id="submit-btn"
          class="w-full bg-flame hover:bg-flame/90 text-white font-medium py-3 rounded transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          Connect
        </button>
        <div id="status" class="text-sm text-slate-400 min-h-[1.25rem] mt-4"></div>
      </form>
      <div class="mt-12 pt-8 border-t border-slate-800 text-sm text-slate-500">
        <p class="mb-2">Don't have a code?</p>
        <p>
          Outcomestar is currently in pilot with select schools. If you're a Roach Middle School family, email
          <a href="mailto:support@outcomestar.app" class="text-flame hover:underline">support@outcomestar.app</a> for access.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const API_BASE = "https://outcomestar-companion-api.onrender.com";
  const APP_URL = "https://app.outcomestar.app/north-star/sync";
  const form = document.getElementById("signup-form");
  const status = document.getElementById("status");
  const submitBtn = document.getElementById("submit-btn");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const codeInput = document.getElementById("code");
    const code = codeInput.value.trim().toUpperCase();
    if (code.length < 4) { status.textContent = "Enter a valid pairing code."; status.className = "text-sm text-amber-400 min-h-[1.25rem] mt-4"; return; }
    submitBtn.disabled = true;
    status.textContent = "Connecting...";
    status.className = "text-sm text-slate-400 min-h-[1.25rem] mt-4";
    try {
      const r = await fetch(API_BASE + "/v1/auth/extension-pair", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ code }),
      });
      const body = await r.json();
      if (!r.ok) { status.textContent = "Pairing failed: " + (body.detail || ("HTTP " + r.status)); status.className = "text-sm text-red-400 min-h-[1.25rem] mt-4"; submitBtn.disabled = false; return; }
      localStorage.setItem("outcomestar_auth", JSON.stringify({ api_token: body.api_token, tenant_id: body.tenant_id, student_ids: body.student_ids, pair_name: body.name }));
      status.textContent = "Connected. Redirecting...";
      status.className = "text-sm text-emerald-400 min-h-[1.25rem] mt-4";
      setTimeout(() => { window.location.href = APP_URL + "#token=" + encodeURIComponent(body.api_token); }, 800);
    } catch (err) {
      status.textContent = "Network error: " + err.message;
      status.className = "text-sm text-red-400 min-h-[1.25rem] mt-4";
      submitBtn.disabled = false;
    }
  });
</script>